# Turborepo Global Environment Variables
# Note: Vite requires VITE_ prefix, so we use VITE_BACKEND_URL and VITE_FRONTEND_URL
# These map to the global BACKEND_URL and FRONTEND_URL variables

# Backend URL - where the backend is hosted (without /api suffix)
# The /api path will be automatically appended
# Development: http://localhost:3000
# Production: https://api.yourdomain.com or https://yourdomain.com
VITE_BACKEND_URL=http://localhost:3000

# Frontend URL - where the frontend application is hosted
# Development: http://localhost:5173
# Production: https://yourdomain.com
VITE_FRONTEND_URL=http://localhost:5173
