{
    "name": "stonkses-backend",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "bun run src/index.ts",
        "dev": "bun run --watch src/index.ts",
        "build": "echo 'Backend does not require build step'",
        "lint": "biome check --write",
        "check-types": "tsc --noEmit",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "deploy": "../../scripts/deploy-backend.sh",
        "deploy:preview": "../../scripts/deploy-backend.sh",
        "deploy:production": "../../scripts/deploy-backend.sh --prod"
    },
    "devDependencies": {
        "@repo/biome-config": "^",
        "@repo/robinhood": "^",
        "@repo/typescript-config": "*",
        "@types/better-sqlite3": "^7.6.13",
        "@types/bun": "latest",
        "drizzle-kit": "^0.31.8"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "better-auth": "^1.4.18",
        "drizzle-orm": "^0.45.1",
        "fastify": "^5.7.2",
        "pino-pretty": "^13.1.3",
        "robinhood": "^1.8.0"
    }
}
