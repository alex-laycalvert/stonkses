{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "tui",
    "globalEnv": ["FRONTEND_URL", "BACKEND_URL"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**", "build/**", ".react-router/**"],
            "env": ["BETTER_AUTH_SECRET"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "typecheck": {
            "dependsOn": ["^typecheck"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "cache": false
        }
    }
}
