{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "tui",
    "globalEnv": ["FRONTEND_URL", "BACKEND_URL", "GITHUB_TOKEN"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**", "build/**", ".react-router/**", ".vercel/**", "!.vercel/cache/**"],
            "env": ["BETTER_AUTH_SECRET"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "typecheck": {
            "dependsOn": ["^typecheck"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "cache": false
        },
        "deploy": {
            "dependsOn": ["build", "lint", "check-types"],
            "cache": false,
            "outputs": [".vercel/**", "!.vercel/cache/**"]
        },
        "deploy:preview": {
            "dependsOn": ["build", "lint", "check-types"],
            "cache": false,
            "outputs": [".vercel/**", "!.vercel/cache/**"]
        },
        "deploy:production": {
            "dependsOn": ["build", "lint", "check-types"],
            "cache": false,
            "outputs": [".vercel/**", "!.vercel/cache/**"]
        }
    }
}
